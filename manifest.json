{
   "background": {
      "scripts": [
         "jsbn.js",
         "rsa.js",
         "req.js",
         "background.js"
      ]
   },
   "browser_action": {
      "default_icon": "icon128.png",
      "default_popup": "popup/popup.html",
      "default_title": "SUM"
   },
   "content_scripts": [
      {
         "all_frames": true,
         "js": [
            "script.js"
         ],
         "matches": [
            "<all_urls>"
         ],
         "run_at": "document_start"
      }
   ],
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "48": "icon48.png"
   },
   "manifest_version": 2,
   "browser_specific_settings": {
      "gecko": {
         "id": "ratonulmiauna@proton.me",
         "data_collection_permissions": {
            "required": [
               "none"
            ]
         },
         "strict_min_version": "142.0"
      }
   },
   "description": "Change Steam Accounts",
   "name": "Steam User Manager",
   "permissions": [
      "<all_urls>",
      "tabs",
      "webRequest",
      "webRequestBlocking",
      "storage",
      "cookies"
      
   ],
   "short_name": "SUM",
   "version": "0.0.7"
}